# ===========================================================================
# talad-ruam — ตัวอย่าง environment variables
# คัดลอกเป็น .env.local แล้วเติมค่าเมื่อจะต่อบริการจริง
# (ถ้าไม่ตั้งค่า แอปจะรันในโหมด demo ด้วยข้อมูลตัวอย่าง + in-memory store)
# ===========================================================================

# ---- Supabase (auth / ฐานข้อมูล / เก็บรูป) ----
# สร้าง project ที่ https://supabase.com แล้วรัน supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key (ฝั่ง server เท่านั้น — งาน admin/moderation ที่ bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ---- LINE ----
# LINE Login (https://developers.line.biz) — ผู้ขาย/ผู้ซื้อล็อกอิน
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# LINE Messaging API — push แจ้งเตือนผู้ขายเมื่อมีคนกด "ติดต่อ"
LINE_CHANNEL_ACCESS_TOKEN=
# LIFF id สำหรับฟอร์มลงสินค้าในแอป LINE
NEXT_PUBLIC_LIFF_ID=

# ---- ตรวจสลิป PromptPay (SlipOK / slip2go / EasySlip) ----
SLIP_VERIFY_API_KEY=
SLIP_VERIFY_ENDPOINT=
# บัญชี PromptPay ปลายทางที่ให้ผู้ขายโอน
PROMPTPAY_ID=

# ---- OTP (ThaiBulkSMS / อื่นๆ) — ยืนยันเบอร์ตอนสมัคร ----
OTP_API_KEY=
OTP_SENDER=
